PAPERTRADE_SOURCE_MODE=platform_forward
PAPERTRADE_RUNTIME_MODE=forward_market_listener
PAPERTRADE_STRATEGY=hybrid_aggressive_safe_valid
PAPERTRADE_REPORT_OUTPUT_DIR=reports
PAPERTRADE_REPORT_FILENAME_PATTERN={strategy}__{run_id}__{as_of_round}__{report_type}.md
PAPERTRADE_INITIAL_EQUITY=100
PAPERTRADE_NOTIONAL_PCT=0.01
PAPERTRADE_FEE_BPS=4
PAPERTRADE_SLIPPAGE_BPS=4
PAPERTRADE_DECISION_BUFFER_SECONDS=30
PAPERTRADE_MARKET_STATE_STALENESS_SECONDS=120
PAPERTRADE_ORDERBOOK_STALENESS_SECONDS=15
PAPERTRADE_STRICT_LIQUIDATION=true
PAPERTRADE_RISKY_ARTIFACT_PATH=
PAPERTRADE_SAFE_ARTIFACT_PATH=
PAPERTRADE_LIVE_PLATFORM_SOURCES=false
PAPERTRADE_BYBIT_REST_BASE_URL=https://api.bybit.com
PAPERTRADE_BITGET_REST_BASE_URL=https://api.bitget.com
PAPERTRADE_PLATFORM_DB_PATH=
PAPERTRADE_MARKET_STATE_SNAPSHOT_PATH=
PAPERTRADE_ORDERBOOK_SNAPSHOT_PATH=
PAPERTRADE_LIQUIDATION_EVENTS_PATH=
